generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  ENGINEER
  REVIEWER
  VIEWER
}

enum TowerClassification {
  SELF_SUPPORTING
  GUYED
}

enum FoundationKind {
  CAISSON
  FOOTING
}

enum FoundationTypeCode {
  TM
  TE
  TR
  S
  SM
  VE
}

enum DataSource {
  THEORETICAL
  FIELD
  RECALCULATED
}

enum DocumentType {
  PDF
  XLS
  DWG
}

enum ProjectType {
  GUYED_HEIGHT_LOCATION
  GUYED_FOUNDATION
  SELF_SUPPORTING_STUBS
  SELF_SUPPORTING_FOUNDATION
}

enum ExtractionStatus {
  PENDING
  EXTRACTED
  VALIDATED
  COMMITTED
  REJECTED
}

enum WorkStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum WorkTowerStatus {
  PENDING
  IN_PROGRESS
  CALCULATED
  EMITTED
}

enum WorkDocumentPipelineStatus {
  UPLOADED
  PROCESSING
  PENDING_REVIEW
  REVIEWED
  FAILED
}

enum ReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum ReviewEntityType {
  TOWER
  LEG
  STAY
  FOUNDATION
  LOCATION
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  name          String
  role          UserRole        @default(VIEWER)
  passwordHash  String
  active        Boolean         @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime        @default(now())
  sessions      Session[]
  auditLogs     SystemAuditLog[]
  works         Work[]

  @@map("users")
}

model Session {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash  String
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())

  @@map("sessions")
}

model SystemAuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  ipAddress   String?
  timestamp   DateTime @default(now())

  @@map("system_audit_logs")
}

// ─── Obra (Work) ──────────────────────────────────────────────────────────────

model Work {
  id             String      @id @default(uuid())
  name           String
  contractNumber String
  description    String?
  status         WorkStatus  @default(DRAFT)
  createdById    String
  createdBy      User        @relation(fields: [createdById], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  workTowers     WorkTower[]
  workDocuments  WorkDocument[]
  reviewItems    ReviewItem[]

  @@map("works")
}

model WorkTower {
  id        String          @id @default(uuid())
  workId    String
  work      Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  towerId   String
  tower     Tower           @relation(fields: [towerId], references: [id])
  sequence  Int
  alias     String?
  status    WorkTowerStatus @default(PENDING)
  createdAt DateTime        @default(now())

  @@unique([workId, sequence])
  @@map("work_towers")
}

model WorkDocument {
  id             String                     @id @default(uuid())
  workId         String
  work           Work                       @relation(fields: [workId], references: [id], onDelete: Cascade)
  fileName       String
  fileType       DocumentType
  storageKey     String?
  pipelineStatus WorkDocumentPipelineStatus @default(UPLOADED)
  uploadedById   String
  uploadedAt     DateTime                   @default(now())

  @@map("work_documents")
}

// ─── Human Validation ─────────────────────────────────────────────────────────

model ReviewItem {
  id               String           @id @default(uuid())
  workId           String
  work             Work             @relation(fields: [workId], references: [id])
  entityType       ReviewEntityType
  status           ReviewStatus     @default(PENDING)
  parsedRecordId   String?
  rejectionReason  String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
  fields           ReviewField[]

  @@map("review_items")
}

model ReviewField {
  id             String       @id @default(uuid())
  reviewItemId   String
  reviewItem     ReviewItem   @relation(fields: [reviewItemId], references: [id], onDelete: Cascade)
  key            String
  extractedValue String
  parsedValue    Json?
  humanValue     Json?
  confidence     Float        @default(1)
  needsReview    Boolean      @default(false)
  overridden     Boolean      @default(false)
  inspected      Boolean      @default(false)
  auditEntries   ReviewAuditEntry[]

  @@unique([reviewItemId, key])
  @@map("review_fields")
}

model ReviewAuditEntry {
  id            String      @id @default(uuid())
  reviewFieldId String
  reviewField   ReviewField @relation(fields: [reviewFieldId], references: [id], onDelete: Cascade)
  userId        String
  action        String
  previousValue Json?
  newValue      Json?
  justification String?
  timestamp     DateTime    @default(now())

  @@map("review_audit_entries")
}

// ─── Project Ingestion ────────────────────────────────────────────────────────

model ProjectDocument {
  id            String           @id @default(uuid())
  filename      String
  documentType  DocumentType
  projectType   ProjectType
  storageKey    String
  status        ExtractionStatus @default(PENDING)
  uploadedAt    DateTime         @default(now())
  towers        Tower[]
  extractedData ExtractedData[]

  @@map("project_documents")
}

model ExtractedData {
  id                String          @id @default(uuid())
  projectDocumentId String
  projectDocument   ProjectDocument @relation(fields: [projectDocumentId], references: [id], onDelete: Cascade)
  towerParams       Json            @default("{}")
  legs              Json            @default("[]")
  elements          Json            @default("[]")
  userEdits         Json            @default("{}")
  validatedAt       DateTime?
  validatedByUserId String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("extracted_data")
}

// ─── Foundation Design ────────────────────────────────────────────────────────

model Tower {
  id                String              @id @default(uuid())
  type              String
  extension         Decimal             @db.Decimal(8, 2)
  hu                Decimal             @db.Decimal(8, 2)
  classification    TowerClassification
  deflectionDeg     Int?
  deflectionMin     Int?
  deflectionSec     Decimal?            @db.Decimal(6, 4)
  deflectionDir     String?
  projectDocumentId String?
  projectDocument   ProjectDocument?    @relation(fields: [projectDocumentId], references: [id])
  dataSource        DataSource          @default(THEORETICAL)
  version           Int                 @default(1)
  legs              Leg[]
  guyedElements     GuyedElement[]
  workTowers        WorkTower[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@map("towers")
}

model Leg {
  id                     String         @id @default(uuid())
  legId                  String         // A|B|C|D
  towerId                String
  tower                  Tower          @relation(fields: [towerId], references: [id], onDelete: Cascade)
  foundationKind         FoundationKind?
  foundationCatalogRefId String?
  foundationGeometry     Json?
  foundationAzimuth      Decimal?       @db.Decimal(8, 4)
  naturalElevation       Decimal?       @db.Decimal(10, 4)
  concreteCastingElev    Decimal?       @db.Decimal(10, 4)
  distance               Decimal?       @db.Decimal(10, 4)
  stubType               String?
  stubLength             Decimal?       @db.Decimal(8, 4)
  stubEmbedment          Decimal?       @db.Decimal(8, 4)
  stubInclination        Decimal?       @db.Decimal(8, 4)
  theoreticalData        Json?
  fieldData              Json?
  dataSource             DataSource     @default(THEORETICAL)

  @@unique([towerId, legId])
  @@map("legs")
}

model GuyedElement {
  id                     String         @id @default(uuid())
  elementId              String         // MC|A|B|C|D
  towerId                String
  tower                  Tower          @relation(fields: [towerId], references: [id], onDelete: Cascade)
  foundationKind         FoundationKind?
  foundationCatalogRefId String?
  foundationGeometry     Json?
  foundationAzimuth      Decimal?       @db.Decimal(8, 4)
  naturalElevation       Decimal?       @db.Decimal(10, 4)
  concreteCastingElev    Decimal?       @db.Decimal(10, 4)
  distance               Decimal?       @db.Decimal(10, 4)
  stayHorizAngleDeg      Int?
  stayHorizAngleMin      Int?
  stayHorizAngleSec      Decimal?       @db.Decimal(6, 4)
  stayInclinationAngle   Decimal?       @db.Decimal(8, 4)
  stubType               String?
  stubLength             Decimal?       @db.Decimal(8, 4)
  stubEmbedment          Decimal?       @db.Decimal(8, 4)
  // Terrain correction fields (pipeline: Fundacao SM-VPM)
  cotaPF                 Decimal?       @db.Decimal(10, 4)
  referencePoint5m       Decimal?       @db.Decimal(10, 4)
  distanceToCC           Decimal?       @db.Decimal(10, 4)
  alfa                   Decimal?       @db.Decimal(12, 8)
  adjustedNCC            Decimal?       @db.Decimal(10, 4)
  adjustedHC             Decimal?       @db.Decimal(10, 4)
  anchorRealDistance     Decimal?       @db.Decimal(10, 4)
  cableCutLength         Decimal?       @db.Decimal(10, 4)
  terrainAdjusted        Boolean        @default(false)
  theoreticalData        Json?
  fieldData              Json?
  dataSource             DataSource     @default(THEORETICAL)

  @@unique([towerId, elementId])
  @@map("guyed_elements")
}

model FoundationCatalogItem {
  id            String              @id @default(uuid())
  catalogRefId  String              @unique
  kind          FoundationKind
  typeCode      FoundationTypeCode
  geometry      Json
  reinforcement Json?
  loadCapacity  Json?               // { compression: number, tension: number } in kN
  description   String?

  @@map("foundation_catalog_items")
}
