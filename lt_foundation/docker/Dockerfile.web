FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json ./
COPY apps/web/package.json ./apps/web/
COPY libs/shared-dtos/package.json ./libs/shared-dtos/
RUN npm install --workspace=apps/web --ignore-scripts
COPY apps/web ./apps/web
COPY tsconfig.base.json ./
COPY libs/shared-dtos ./libs/shared-dtos
RUN cd apps/web && npx ng build --configuration production

FROM nginx:alpine AS runner
COPY --from=builder /app/apps/web/dist/lt-web/browser /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
